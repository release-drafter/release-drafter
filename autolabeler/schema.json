{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "_extends": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "properties": {
            "from": {
              "type": "string",
              "minLength": 1
            },
            "strategy": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {
                "type": "string",
                "enum": ["override", "append", "prepend"]
              }
            }
          },
          "required": ["from"],
          "additionalProperties": false
        }
      ]
    },
    "autolabeler": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "files": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "branch": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "title": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "body": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": ["label"]
      }
    }
  },
  "required": ["autolabeler"],
  "title": "JSON schema for Release Drafter's autolabeler action config."
}
